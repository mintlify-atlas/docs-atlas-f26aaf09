  "keyFeatures": [
    "Full-stack web framework with Python and JavaScript",
    "Metadata-driven DocType system for rapid development",
    "Built-in admin interface with forms, lists, and reports",
    "Role-based permissions and user management",
    "Automatically generated REST API for all models",
    "Background job processing with RQ",
    "Real-time updates via Socket.IO",
    "Email integration and workflow engine",
    "Multi-tenant architecture with site management",
    "Database abstraction supporting MariaDB and PostgreSQL"
  ],
